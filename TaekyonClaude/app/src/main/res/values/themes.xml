<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.TaekyonClaude" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@android:color/black</item>
    </style>

    <!-- Light-mode splash: warm cream bg, dark-circle icon for contrast -->
    <style name="Theme.TaekyonClaude.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F6F1EA</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="windowSplashScreenIconBackgroundColor">#100C08</item>
        <item name="postSplashScreenTheme">@style/Theme.TaekyonClaude</item>
    </style>

</resources>